# 后端服务配置（复制为 .env 后填写）

# 服务端口
PORT=8787

# 允许的前端来源，开发时可留空（*）
FRONTEND_ORIGIN=

# ── 淘宝/天猫登录态 Cookie（用于绕过反爬、抓取真实商品标题/主图/价格）──
# 获取方式：电脑浏览器登录淘宝/天猫 → F12 开发者工具 → Network →
#   随便点一个 item.taobao.com 或 detail.tmall.com 的请求 →
#   复制 Request Headers 里的整段 Cookie 值粘到这里（以 ; 分隔的长字符串）。
# 注意：Cookie 含登录凭证，请勿泄露、勿提交到 git；仅用于你自己本地解析。
# 留空则走 OG 抓取 + 手动选服装兜底。Cookie 会过期（几天~几周），失效后重新复制即可。
TAOBAO_COOKIE=

# ── AI 试衣（OpenAI 兼容图像生成 · 默认对接 Agnes Image 2.0 Flash）──
# 文档：https://agnes-ai.com/zh-Hans/docs/agnes-image-20-flash
# 接口：POST {IMAGE_BASE_URL}{IMAGE_ENDPOINT}，Bearer 鉴权，JSON 请求体
# 图生图：把自拍照放进 extra_body.image 数组；输出用 extra_body.response_format
# 你只需在下方填好三样：base_url、api_key、model（默认值已按 Agnes 填好，按需改）。

# 接口基地址
IMAGE_BASE_URL=https://apihub.agnes-ai.com/v1

# 你的 API Key（在 Agnes 平台获取）
IMAGE_API_KEY=YOUR_API_KEY

# 模型名
IMAGE_MODEL=agnes-image-2.0-flash

# 端点路径（拼接规则：IMAGE_BASE_URL + IMAGE_ENDPOINT）
IMAGE_ENDPOINT=/images/generations

# 生成尺寸（Agnes 支持 1024x768 / 1024x1024 / 768x1024）
IMAGE_SIZE=1024x1024

# ── 商品图视觉识别（多模态兜底 · 默认复用 Agnes agnes-2.0-flash）──
# 用途：当 HTML 文本只拿到主图、拿不到标题/价格/服装类型时，后端会自动把商品图
#   发给一个「能读图」的模型，结构化识别出 {标题, 价格, 服装类型, 颜色, 部位} 并自动填充，
#   免去手动选择。文档：https://agnes-ai.com/zh-Hans/docs/agnes-20-flash
# 默认复用上面的 IMAGE_BASE_URL / IMAGE_API_KEY，模型用 agnes-2.0-flash（与画图模型同 Key）。
# 若你有其它 OpenAI 兼容视觉模型，可在此覆盖；留空则自动复用 IMAGE_* 配置。
# VISION_BASE_URL=https://apihub.agnes-ai.com/v1
# VISION_API_KEY=YOUR_API_KEY
VISION_MODEL=agnes-2.0-flash
# 视觉识别超时（毫秒）
VISION_TIMEOUT=20000
